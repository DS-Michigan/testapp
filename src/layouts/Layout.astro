---
import '../styles/global.css';
import config from '../data/config.json';

interface Props {
  title?: string;
}
const { title } = Astro.props;
const pageTitle = title ? `${title} | ${config.leagueName}` : config.leagueName;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body class="bg-stone-950 text-stone-100 min-h-screen font-sans">

  <header class="bg-green-900 border-b border-green-700 shadow-lg">
    <div class="max-w-5xl mx-auto px-4 py-4 flex flex-col sm:flex-row items-center justify-between gap-3">
      <a href="/" class="flex items-center gap-3 group">
        <span class="text-3xl">⛳</span>
        <div>
          <div class="text-xl font-bold text-white leading-tight group-hover:text-green-200 transition-colors">{config.leagueName}</div>
          <div class="text-green-300 text-sm">{config.season} Season &bull; Week {config.currentWeek} of {config.totalWeeks}</div>
        </div>
      </a>
      <nav class="flex gap-1">
        <a href="/" class="px-3 py-1.5 rounded text-sm font-medium text-green-100 hover:bg-green-700 hover:text-white transition-colors">Home</a>
        <a href="/standings" class="px-3 py-1.5 rounded text-sm font-medium text-green-100 hover:bg-green-700 hover:text-white transition-colors">Standings</a>
        <a href="/h2h" class="px-3 py-1.5 rounded text-sm font-medium text-green-100 hover:bg-green-700 hover:text-white transition-colors">Head-to-Head</a>
        <a href="/newsletter" class="px-3 py-1.5 rounded text-sm font-medium text-green-100 hover:bg-green-700 hover:text-white transition-colors">Newsletter</a>
      </nav>
    </div>
  </header>

  <main class="max-w-5xl mx-auto px-4 py-8">
    <slot />
  </main>

  <footer class="border-t border-stone-800 mt-16 py-6 text-center text-stone-500 text-sm">
    {config.leagueName} &bull; {config.season}
  </footer>

</body>
</html>
