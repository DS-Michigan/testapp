---
import Layout from '../layouts/Layout.astro';
import StandingsTable from '../components/StandingsTable.astro';
import { computeStandings } from '../lib/standings';

const northStandings = computeStandings('north');
const southStandings = computeStandings('south');
---
<Layout title="Standings">
  <h1 class="text-3xl font-bold text-white mb-1">League Standings</h1>
  <p class="text-slate-400 mb-8 text-sm">Points: 1 for a win &bull; 0.5 for a halve &bull; 0 for a loss</p>

  <div class="grid md:grid-cols-2 gap-8">
    <StandingsTable standings={northStandings} flight="North" />
    <StandingsTable standings={southStandings} flight="South" />
  </div>
</Layout>
