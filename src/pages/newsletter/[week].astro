---
import Layout from '../../layouts/Layout.astro';
import newsletterData from '../../data/newsletter.json';

export function getStaticPaths() {
  return newsletterData.map(issue => ({
    params: { week: String(issue.week) },
    props: { issue },
  }));
}

const { issue } = Astro.props;
const paragraphs = issue.content.split('\n\n');
---
<Layout title={`Week ${issue.week} Recap`}>
  <div class="max-w-2xl mx-auto">
    <a href="/newsletter" class="text-stone-500 hover:text-stone-300 text-sm transition-colors mb-6 inline-block">← All issues</a>

    <div class="text-xs text-stone-500 mb-2">Week {issue.week} &bull; {issue.date}</div>
    <h1 class="text-3xl font-bold text-white mb-6">{issue.title}</h1>

    <div class="bg-stone-900 rounded-xl border border-stone-800 p-6 md:p-8 space-y-4">
      <p class="text-green-300 font-medium text-lg border-l-4 border-green-600 pl-4">{issue.summary}</p>
      {paragraphs.map(p => (
        <p class="text-stone-300 leading-relaxed">{p}</p>
      ))}
    </div>

    <div class="flex gap-4 mt-8">
      {newsletterData.find(i => i.week === issue.week - 1) && (
        <a href={`/newsletter/${issue.week - 1}`} class="text-green-400 hover:text-green-300 text-sm transition-colors">← Previous week</a>
      )}
      {newsletterData.find(i => i.week === issue.week + 1) && (
        <a href={`/newsletter/${issue.week + 1}`} class="ml-auto text-green-400 hover:text-green-300 text-sm transition-colors">Next week →</a>
      )}
    </div>
  </div>
</Layout>
