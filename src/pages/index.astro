---
import Layout from '../layouts/Layout.astro';
import StandingsTable from '../components/StandingsTable.astro';
import { computeStandings } from '../lib/standings';
import newsletterData from '../data/newsletter.json';
import matchesData from '../data/matches.json';
import teamsData from '../data/teams.json';
import config from '../data/config.json';

const northStandings = computeStandings('north').slice(0, 5);
const southStandings = computeStandings('south').slice(0, 5);
const latestNewsletter = newsletterData[newsletterData.length - 1];
const currentWeekMatches = matchesData.filter(w => w.week === config.currentWeek);

function teamName(id: string) {
  const all = [...teamsData.north, ...teamsData.south];
  return all.find(t => t.id === id)?.name ?? id;
}

function resultLabel(result: string, homeId: string, awayId: string) {
  if (result === 'tie') return 'Tied';
  const winner = result === 'home' ? homeId : awayId;
  return `${teamName(winner)} won`;
}
---
<Layout>
  <div class="text-center mb-10">
    <h1 class="text-3xl font-bold text-white mb-2">Welcome to the League</h1>
    <p class="text-stone-400">Check in each week for updated standings, match results, and the weekly newsletter.</p>
  </div>

  {currentWeekMatches.length > 0 && (
    <section class="mb-10">
      <h2 class="text-xl font-bold text-white mb-4">Week {config.currentWeek} Results</h2>
      <div class="grid md:grid-cols-2 gap-4">
        {currentWeekMatches.map(weekFlight => (
          <div class="bg-stone-900 rounded-xl border border-stone-800 overflow-hidden">
            <div class="bg-green-800 px-4 py-2 font-semibold text-white capitalize">{weekFlight.flight} Flight</div>
            <ul class="divide-y divide-stone-800">
              {weekFlight.matches.map(m => (
                <li class="px-4 py-3 text-sm">
                  <div class="flex justify-between items-center gap-2">
                    <span class="text-stone-300">{teamName(m.home)} vs {teamName(m.away)}</span>
                    <span class={`text-xs font-semibold px-2 py-0.5 rounded-full whitespace-nowrap ${m.result === 'tie' ? 'bg-yellow-900 text-yellow-300' : 'bg-green-900 text-green-300'}`}>
                      {resultLabel(m.result, m.home, m.away)}
                    </span>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>
  )}

  <section class="mb-10">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-xl font-bold text-white">Standings</h2>
      <a href="/standings" class="text-green-400 hover:text-green-300 text-sm transition-colors">View full standings →</a>
    </div>
    <div class="grid md:grid-cols-2 gap-6">
      <StandingsTable standings={northStandings} flight="North" />
      <StandingsTable standings={southStandings} flight="South" />
    </div>
  </section>

  {latestNewsletter && (
    <section>
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xl font-bold text-white">Latest Newsletter</h2>
        <a href="/newsletter" class="text-green-400 hover:text-green-300 text-sm transition-colors">All issues →</a>
      </div>
      <div class="bg-stone-900 rounded-xl border border-stone-800 p-6">
        <div class="text-xs text-stone-500 mb-1">Week {latestNewsletter.week} &bull; {latestNewsletter.date}</div>
        <h3 class="text-xl font-bold text-white mb-2">{latestNewsletter.title}</h3>
        <p class="text-stone-300 mb-4">{latestNewsletter.summary}</p>
        <a href={`/newsletter/${latestNewsletter.week}`} class="text-green-400 hover:text-green-300 text-sm transition-colors">Read full recap →</a>
      </div>
    </section>
  )}
</Layout>
