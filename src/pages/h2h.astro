---
import Layout from '../layouts/Layout.astro';
import { getAllTeams, computeH2H } from '../lib/standings';

const { north, south } = getAllTeams();
const allTeams = [...north, ...south];

const teamRecords = allTeams.map(team => ({
  team,
  flight: north.find(t => t.id === team.id) ? 'North' : 'South',
  h2h: computeH2H(team.id),
}));

const northRecords = teamRecords.filter(r => r.flight === 'North');
const southRecords = teamRecords.filter(r => r.flight === 'South');
---
<Layout title="Head-to-Head">
  <h1 class="text-3xl font-bold text-white mb-1">Head-to-Head Records</h1>
  <p class="text-slate-400 mb-8 text-sm">All-time records between teams within each flight.</p>

  {[{ label: 'North Flight', records: northRecords }, { label: 'South Flight', records: southRecords }].map(({ label, records }) => (
    <section class="mb-12">
      <h2 class="text-lg font-bold text-amber-400 mb-4 pb-2 border-b border-slate-800 uppercase tracking-wide">{label}</h2>
      <div class="space-y-4">
        {records.map(({ team, h2h }) => (
          <div class="bg-slate-900 rounded-xl border border-slate-700 overflow-hidden">
            <div class="px-4 py-3 bg-slate-800">
              <div class="font-bold text-white">{team.name}</div>
              <div class="text-slate-400 text-xs">{team.players.join(' & ')}</div>
            </div>
            {h2h.length === 0 ? (
              <p class="px-4 py-3 text-slate-500 text-sm italic">No matches played yet.</p>
            ) : (
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-slate-800 text-slate-500 text-xs uppercase">
                    <th class="px-4 py-2 text-left">Opponent</th>
                    <th class="px-4 py-2 text-center">W</th>
                    <th class="px-4 py-2 text-center">L</th>
                    <th class="px-4 py-2 text-center">H</th>
                    <th class="px-4 py-2 text-right">Pts</th>
                  </tr>
                </thead>
                <tbody>
                  {h2h.map(r => (
                    <tr class="border-b border-slate-800 last:border-0 hover:bg-slate-800/50 transition-colors">
                      <td class="px-4 py-2.5 text-slate-200">{r.opponent.name}</td>
                      <td class="px-4 py-2.5 text-center text-green-400 font-mono">{r.wins}</td>
                      <td class="px-4 py-2.5 text-center text-red-400 font-mono">{r.losses}</td>
                      <td class="px-4 py-2.5 text-center text-slate-400 font-mono">{r.ties}</td>
                      <td class="px-4 py-2.5 text-right text-amber-400 font-bold font-mono">{r.points}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            )}
          </div>
        ))}
      </div>
    </section>
  ))}
</Layout>
